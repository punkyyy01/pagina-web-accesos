---
import BaseLayout from '../layouts/BaseLayout.astro';
import BentoGrid from '../components/BentoGrid.astro';
import '../styles/global.css';
---

<BaseLayout>

<!-- ════════════════════════════════════════════════════════════════
     1. HERO — Editorial, tipografía serif, autoridad clínica
════════════════════════════════════════════════════════════════ -->
<section id="hero" class="hero-bg min-h-screen flex flex-col justify-center pt-20">
  <div class="container-section py-16 sm:py-24">

    <div class="max-w-3xl">

      <!-- Eyebrow -->
      <div id="hero-eyebrow" class="mb-8">
        <div class="flex items-center gap-3">
          <div class="w-8 h-px" style="background: var(--accent);"></div>
          <span class="text-[10px] sm:text-[11px] font-semibold tracking-[0.25em] uppercase" style="color: var(--accent);">
            Educación Clínica
          </span>
        </div>
      </div>

      <!-- Title -->
      <h1 id="hero-title" class="text-[2.5rem] sm:text-[3.5rem] lg:text-[4.25rem] leading-[1.08] tracking-tight mb-8"
          style="font-family: var(--font-display);">
        <span class="text-white">Dispositivos de</span><br/>
        <span style="color: var(--accent-2);">
          <em>Acceso Vascular</em>
        </span>
      </h1>

      <!-- Description -->
      <p id="hero-desc" class="text-base sm:text-lg leading-relaxed mb-10 max-w-xl" style="color: var(--muted);">
        Guía clínica rápida para personal de enfermería y medicina.
        Selección del dispositivo correcto, recorrido anatómico y seguridad en la inserción.
      </p>

      <!-- Device pills -->
      <div id="hero-pills" class="flex flex-wrap gap-3 mb-16">
        <a href="#fichas" data-target="picc"
           class="badge badge-picc px-4 py-2.5 text-[12px] hover:scale-[1.03] transition-all duration-300 cursor-pointer hover:shadow-lg hover:shadow-emerald-500/10">
          <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
          PICC
        </a>
        <a href="#fichas" data-target="cvc-subclavio"
           class="badge badge-cvc-sub px-4 py-2.5 text-[12px] hover:scale-[1.03] transition-all duration-300 cursor-pointer hover:shadow-lg hover:shadow-orange-500/10">
          <span class="w-1.5 h-1.5 rounded-full bg-orange-500"></span>
          CVC Subclavio
        </a>
        <a href="#fichas" data-target="cvc-yugular"
           class="badge badge-cvc-yug px-4 py-2.5 text-[12px] hover:scale-[1.03] transition-all duration-300 cursor-pointer hover:shadow-lg hover:shadow-violet-500/10">
          <span class="w-1.5 h-1.5 rounded-full bg-violet-500"></span>
          CVC Yugular
        </a>
        <a href="#fichas" data-target="midline"
           class="badge badge-midline px-4 py-2.5 text-[12px] hover:scale-[1.03] transition-all duration-300 cursor-pointer hover:shadow-lg hover:shadow-cyan-500/10">
          <span class="w-1.5 h-1.5 rounded-full bg-cyan-500"></span>
          Midline
        </a>
      </div>

      <!-- Scroll indicator -->
      <div id="hero-scroll" class="flex items-center gap-4" style="color: var(--subtle);">
        <div class="w-5 h-9 border rounded-full flex items-start justify-center pt-2" style="border-color: var(--border-2);">
          <div id="scroll-dot" class="w-1 h-1 rounded-full" style="background: var(--accent);"></div>
        </div>
        <span class="text-[11px] tracking-wider uppercase">Explorar guía</span>
      </div>

    </div>

    <!-- Decorative line on the right -->
    <div class="hidden lg:block absolute right-16 top-1/2 -translate-y-1/2 w-px h-48 opacity-20"
         style="background: linear-gradient(to bottom, transparent, var(--accent), transparent);"></div>

  </div>
</section>

<!-- ════════════════════════════════════════════════════════════════
     2. REFERENCIA RÁPIDA — Selección en 5 segundos
════════════════════════════════════════════════════════════════ -->
<section id="referencia" class="section-alt" style="padding: var(--section-py) 0;">
  <div class="container-section">

    <div class="text-center mb-14 reveal">
      <p class="section-label">Referencia rápida</p>
      <div class="section-divider"></div>
      <h2 class="section-title">¿Qué dispositivo <em>necesito</em>?</h2>
      <p class="section-subtitle mx-auto">
        Diseñado para consultas en menos de 5 segundos durante un turno.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">

      <!-- NPT / Quimio -->
      <div class="qref-card reveal">
        <div class="flex items-center gap-3 mb-4">
          <span class="w-9 h-9 rounded-xl flex items-center justify-center text-sm"
                style="background: rgba(52,211,153,0.08); border: 1px solid rgba(52,211,153,0.12);">🧪</span>
          <span class="text-[10px] font-semibold uppercase tracking-[0.2em]" style="color: var(--muted);">NPT / Quimio</span>
        </div>
        <p class="text-[15px] font-bold text-white mb-1.5" style="font-family: var(--font-display);">PICC o CVC</p>
        <p class="text-xs leading-relaxed" style="color: var(--muted);">Requiere catéter central. Punta en VCS para dilución adecuada.</p>
        <div class="mt-4 flex gap-1.5">
          <span class="ind-pill yes">PICC</span>
          <span class="ind-pill yes">CVC</span>
          <span class="ind-pill no">Midline</span>
        </div>
      </div>

      <!-- Antibioterapia -->
      <div class="qref-card reveal">
        <div class="flex items-center gap-3 mb-4">
          <span class="w-9 h-9 rounded-xl flex items-center justify-center text-sm"
                style="background: rgba(34,211,238,0.08); border: 1px solid rgba(34,211,238,0.12);">💊</span>
          <span class="text-[10px] font-semibold uppercase tracking-[0.2em]" style="color: var(--muted);">Antibioterapia IV</span>
        </div>
        <p class="text-[15px] font-bold text-white mb-1.5" style="font-family: var(--font-display);">Midline o PICC</p>
        <p class="text-xs leading-relaxed" style="color: var(--muted);">Si pH 5–9 y duración &lt;4 semanas: Midline es suficiente.</p>
        <div class="mt-4 flex gap-1.5">
          <span class="ind-pill yes">Midline</span>
          <span class="ind-pill yes">PICC</span>
        </div>
      </div>

      <!-- Urgencia / UCI -->
      <div class="qref-card reveal">
        <div class="flex items-center gap-3 mb-4">
          <span class="w-9 h-9 rounded-xl flex items-center justify-center text-sm"
                style="background: rgba(251,146,60,0.08); border: 1px solid rgba(251,146,60,0.12);">🚨</span>
          <span class="text-[10px] font-semibold uppercase tracking-[0.2em]" style="color: var(--muted);">Urgencia / UCI</span>
        </div>
        <p class="text-[15px] font-bold text-white mb-1.5" style="font-family: var(--font-display);">CVC Yugular o Subclavio</p>
        <p class="text-xs leading-relaxed" style="color: var(--muted);">Acceso rápido, ruta corta a VCS. Guía ecográfica si disponible.</p>
        <div class="mt-4 flex gap-1.5">
          <span class="ind-pill yes">CVC Yug</span>
          <span class="ind-pill yes">CVC Sub</span>
        </div>
      </div>

      <!-- Hidratación / Analgesia -->
      <div class="qref-card reveal">
        <div class="flex items-center gap-3 mb-4">
          <span class="w-9 h-9 rounded-xl flex items-center justify-center text-sm"
                style="background: rgba(96,165,250,0.08); border: 1px solid rgba(96,165,250,0.12);">💧</span>
          <span class="text-[10px] font-semibold uppercase tracking-[0.2em]" style="color: var(--muted);">Hidratación</span>
        </div>
        <p class="text-[15px] font-bold text-white mb-1.5" style="font-family: var(--font-display);">Midline</p>
        <p class="text-xs leading-relaxed" style="color: var(--muted);">Si fármacos con pH 5–9 y osmol &lt;600. Evitar acceso central innecesario.</p>
        <div class="mt-4 flex gap-1.5">
          <span class="ind-pill yes">Midline</span>
          <span class="ind-pill yes">PICC</span>
        </div>
      </div>

    </div>
  </div>
</section>

<!-- ════════════════════════════════════════════════════════════════
     3. BENTO GRID — Comparación interactiva
════════════════════════════════════════════════════════════════ -->
<section id="dispositivos" style="padding: var(--section-py) 0;">
  <div class="container-section">

    <div class="text-center mb-14 reveal">
      <p class="section-label">Dispositivos</p>
      <div class="section-divider"></div>
      <h2 class="section-title">Comparación de <em>Accesos Vasculares</em></h2>
      <p class="section-subtitle mx-auto">
        Datos técnicos clave para seleccionar el dispositivo adecuado según la terapia y el paciente.
      </p>
    </div>

    <BentoGrid />

  </div>
</section>

<!-- ════════════════════════════════════════════════════════════════
     4. FICHAS TÉCNICAS — Acordeón expandible
════════════════════════════════════════════════════════════════ -->
<section id="fichas" class="section-alt" style="padding: var(--section-py) 0;">
  <div class="container-section">

    <div class="text-center mb-14 reveal">
      <p class="section-label">Fichas Técnicas</p>
      <div class="section-divider"></div>
      <h2 class="section-title">Especificaciones <em>Clínicas</em></h2>
      <p class="section-subtitle mx-auto">Haz clic en cada dispositivo para ver la ficha completa.</p>
    </div>

    <div class="space-y-4 max-w-5xl mx-auto" id="accordion-group">

      <!-- PICC -->
      <div class="accordion-item reveal" data-accordion="picc">
        <button class="accordion-trigger group" aria-expanded="true">
          <div class="flex items-center gap-4">
            <div class="w-10 h-10 rounded-xl flex items-center justify-center"
                 style="background: rgba(52,211,153,0.08); border: 1px solid rgba(52,211,153,0.15);">
              <span class="w-2.5 h-2.5 rounded-full bg-emerald-500"></span>
            </div>
            <div class="text-left">
              <p class="text-[10px] text-emerald-400 font-semibold uppercase tracking-[0.2em] mb-0.5">PICC</p>
              <p class="text-white font-semibold text-[15px]">Catéter Central de Inserción Periférica</p>
            </div>
          </div>
          <svg class="accordion-icon w-5 h-5 transition-transform duration-300 rotate-180 shrink-0" style="color: var(--muted);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
          </svg>
        </button>
        <div class="accordion-content">
          <div class="px-6 pb-6">
            <div class="h-px mb-6" style="background: var(--border);"></div>
            <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
              <!-- Especificaciones -->
              <div>
                <p class="text-[10px] font-semibold uppercase tracking-[0.2em] mb-4" style="color: var(--subtle);">Especificaciones</p>
                <dl class="space-y-3">
                  {[
                    ['Longitud', '45–65 cm'],
                    ['Calibre', '3–6 Fr (1–3 lúmenes)'],
                    ['Punto inserción', 'Fosa antecubital (v. basílica)'],
                    ['Posición punta', 'VCS / Unión cavoatrial'],
                    ['Duración', 'Semanas–meses'],
                    ['Verificación pos.', 'ECG intravascular o Rx tórax'],
                  ].map(([k, v]) => (
                    <div class="flex justify-between gap-4 text-sm pb-2.5" style="border-bottom: 1px solid var(--border);">
                      <dt style="color: var(--muted);">{k}</dt>
                      <dd class="text-white text-right font-medium">{v}</dd>
                    </div>
                  ))}
                </dl>
              </div>
              <!-- Indicaciones -->
              <div>
                <p class="text-[10px] font-semibold uppercase tracking-[0.2em] mb-4" style="color: var(--subtle);">Indicaciones</p>
                <ul class="space-y-2 text-sm">
                  {[
                    'Quimioterapia (todos los esquemas)',
                    'Nutrición parenteral total (NPT)',
                    'Antibioterapia IV prolongada (&gt;7 días)',
                    'Hemoderivados',
                    'Fármacos con pH &lt;5 o &gt;9',
                    'Medicación hiperosmolar (&gt;600 mOsm/L)',
                  ].map(i => (
                    <li class="flex gap-2.5" style="color: var(--muted);">
                      <span class="text-emerald-400 font-bold shrink-0">✓</span>
                      <span set:html={i}></span>
                    </li>
                  ))}
                </ul>
              </div>
              <!-- Recorrido + Seguridad -->
              <div class="space-y-5">
                <div>
                  <p class="text-[10px] font-semibold uppercase tracking-[0.2em] mb-4" style="color: var(--subtle);">Recorrido anatómico</p>
                  <ol class="space-y-2 text-sm" style="color: var(--muted);">
                    <li class="flex gap-2"><span class="text-emerald-400 font-bold shrink-0">1.</span> Fosa antecubital (v. basílica preferida)</li>
                    <li class="flex gap-2"><span class="text-emerald-400 font-bold shrink-0">2.</span> Vena axilar</li>
                    <li class="flex gap-2"><span class="text-emerald-400 font-bold shrink-0">3.</span> Vena subclavia (cruza bajo clavícula)</li>
                    <li class="flex gap-2"><span class="text-emerald-400 font-bold shrink-0">4.</span> Vena braquiocefálica</li>
                    <li class="flex gap-2"><span class="text-emerald-500 font-bold shrink-0">5.</span> <strong class="text-emerald-400">VCS / Unión cavoatrial</strong></li>
                  </ol>
                </div>
                <div class="alert alert-warn text-xs">
                  <span class="shrink-0">⚠</span>
                  <div>
                    <strong class="text-amber-400">Punta NO en aurícula derecha</strong><br/>
                    <span style="color: var(--muted);">Riesgo de arritmias. Retirar 2–3 cm si se observa en Rx.</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- CVC Subclavio -->
      <div class="accordion-item reveal" data-accordion="cvc-subclavio">
        <button class="accordion-trigger group" aria-expanded="false">
          <div class="flex items-center gap-4">
            <div class="w-10 h-10 rounded-xl flex items-center justify-center"
                 style="background: rgba(251,146,60,0.08); border: 1px solid rgba(251,146,60,0.15);">
              <span class="w-2.5 h-2.5 rounded-full bg-orange-500"></span>
            </div>
            <div class="text-left">
              <p class="text-[10px] text-orange-400 font-semibold uppercase tracking-[0.2em] mb-0.5">CVC Subclavio</p>
              <p class="text-white font-semibold text-[15px]">Catéter Venoso Central — Abordaje Subclavio</p>
            </div>
          </div>
          <svg class="accordion-icon w-5 h-5 transition-transform duration-300 shrink-0" style="color: var(--muted);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
          </svg>
        </button>
        <div class="accordion-content">
          <div class="px-6 pb-6">
            <div class="h-px mb-6" style="background: var(--border);"></div>
            <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
              <div>
                <p class="text-[10px] font-semibold uppercase tracking-[0.2em] mb-4" style="color: var(--subtle);">Especificaciones</p>
                <dl class="space-y-3">
                  {[
                    ['Longitud', '15–20 cm'],
                    ['Calibre', '7–8.5 Fr (multilumen)'],
                    ['Punto inserción', '1/3 medio clavícula (infra)'],
                    ['Posición punta', 'VCS tercio inferior'],
                    ['Verificación', 'Rx tórax obligatoria'],
                    ['Complicación prin.', 'Neumotórax (~2%)'],
                  ].map(([k, v]) => (
                    <div class="flex justify-between gap-4 text-sm pb-2.5" style="border-bottom: 1px solid var(--border);">
                      <dt style="color: var(--muted);">{k}</dt>
                      <dd class="text-white text-right font-medium">{v}</dd>
                    </div>
                  ))}
                </dl>
              </div>
              <div>
                <p class="text-[10px] font-semibold uppercase tracking-[0.2em] mb-4" style="color: var(--subtle);">Recorrido</p>
                <ol class="space-y-2 text-sm mb-5" style="color: var(--muted);">
                  <li class="flex gap-2"><span class="text-orange-400 font-bold shrink-0">1.</span> Punción infraclavicular 1/3 medio, ángulo 15–30°</li>
                  <li class="flex gap-2"><span class="text-orange-400 font-bold shrink-0">2.</span> Entrada directa a vena subclavia</li>
                  <li class="flex gap-2"><span class="text-orange-400 font-bold shrink-0">3.</span> Vena braquiocefálica derecha</li>
                  <li class="flex gap-2"><span class="text-orange-500 font-bold shrink-0">4.</span> <strong class="text-orange-400">VCS tercio inferior</strong></li>
                </ol>
                <div class="alert alert-info text-xs">
                  <span class="text-blue-400 shrink-0">✦</span>
                  <span style="color: var(--muted);">Ventaja: menor desplazamiento del catéter con movimientos del paciente.</span>
                </div>
              </div>
              <div>
                <p class="text-[10px] font-semibold uppercase tracking-[0.2em] mb-4" style="color: var(--subtle);">Complicaciones</p>
                <ul class="space-y-2.5 text-sm">
                  {[
                    ['Neumotórax', '~2%', 'amber'],
                    ['Hemotórax', 'Raro', 'red'],
                    ['Malposición', 'Yugular, homolateral', 'amber'],
                    ['Síndrome pinch-off', 'Compresión costo-clavicular', 'amber'],
                    ['Trombosis', 'PICC > subclavio', 'blue'],
                  ].map(([c, freq, color]) => (
                    <li class="flex items-start gap-2.5">
                      <span class={`text-${color}-400 font-bold shrink-0 mt-0.5`}>!</span>
                      <div>
                        <span class="text-white font-medium">{c}</span>
                        <span class="text-xs ml-1.5" style="color: var(--muted);">{freq}</span>
                      </div>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- CVC Yugular -->
      <div class="accordion-item reveal" data-accordion="cvc-yugular">
        <button class="accordion-trigger group" aria-expanded="false">
          <div class="flex items-center gap-4">
            <div class="w-10 h-10 rounded-xl flex items-center justify-center"
                 style="background: rgba(167,139,250,0.08); border: 1px solid rgba(167,139,250,0.15);">
              <span class="w-2.5 h-2.5 rounded-full bg-violet-500"></span>
            </div>
            <div class="text-left">
              <p class="text-[10px] text-violet-400 font-semibold uppercase tracking-[0.2em] mb-0.5">CVC Yugular</p>
              <p class="text-white font-semibold text-[15px]">Catéter Venoso Central — Abordaje Yugular Interno</p>
            </div>
          </div>
          <svg class="accordion-icon w-5 h-5 transition-transform duration-300 shrink-0" style="color: var(--muted);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
          </svg>
        </button>
        <div class="accordion-content">
          <div class="px-6 pb-6">
            <div class="h-px mb-6" style="background: var(--border);"></div>
            <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
              <div>
                <p class="text-[10px] font-semibold uppercase tracking-[0.2em] mb-4" style="color: var(--subtle);">Especificaciones</p>
                <dl class="space-y-3">
                  {[
                    ['Longitud derecho', '12–15 cm'],
                    ['Longitud izquierdo', '15–20 cm'],
                    ['Calibre', '7–8.5 Fr'],
                    ['Inserción', 'Triángulo del ECM'],
                    ['Posición punta', 'VCS tercio inferior'],
                    ['Guía recomendada', 'Ultrasonido (reduce comp. 70%)'],
                  ].map(([k, v]) => (
                    <div class="flex justify-between gap-4 text-sm pb-2.5" style="border-bottom: 1px solid var(--border);">
                      <dt style="color: var(--muted);">{k}</dt>
                      <dd class="text-white text-right font-medium">{v}</dd>
                    </div>
                  ))}
                </dl>
              </div>
              <div>
                <p class="text-[10px] font-semibold uppercase tracking-[0.2em] mb-4" style="color: var(--subtle);">Recorrido (vía derecha)</p>
                <ol class="space-y-2 text-sm mb-5" style="color: var(--muted);">
                  <li class="flex gap-2"><span class="text-violet-400 font-bold shrink-0">1.</span> Punción en ángulo del triángulo ECM</li>
                  <li class="flex gap-2"><span class="text-violet-400 font-bold shrink-0">2.</span> Descenso por yugular interna derecha</li>
                  <li class="flex gap-2"><span class="text-violet-400 font-bold shrink-0">3.</span> Unión yugulo-subclavia → braquiocefálica</li>
                  <li class="flex gap-2"><span class="text-violet-500 font-bold shrink-0">4.</span> <strong class="text-violet-400">VCS — ruta casi recta</strong></li>
                </ol>
                <div class="alert alert-success text-xs">
                  <span class="text-emerald-400 shrink-0">✓</span>
                  <span style="color: var(--muted);">La vía derecha ofrece trayecto casi recto a VCS, reduciendo riesgo de malposición.</span>
                </div>
              </div>
              <div>
                <p class="text-[10px] font-semibold uppercase tracking-[0.2em] mb-4" style="color: var(--subtle);">Puntos de seguridad</p>
                <ul class="space-y-2.5 text-sm" style="color: var(--muted);">
                  <li class="flex gap-2"><span class="text-violet-400 shrink-0">→</span> Guía ecográfica reduce riesgo de punción carotídea</li>
                  <li class="flex gap-2"><span class="text-violet-400 shrink-0">→</span> Verificar reflejo venoso (pulsación oscura vs arteria brillante)</li>
                  <li class="flex gap-2"><span class="text-violet-400 shrink-0">→</span> Rx tórax postprocedimiento para confirmar posición</li>
                  <li class="flex gap-2"><span class="text-amber-400 shrink-0">!</span> Riesgo de punción carotídea: 0.5–1%</li>
                </ul>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Midline -->
      <div class="accordion-item reveal" data-accordion="midline">
        <button class="accordion-trigger group" aria-expanded="false">
          <div class="flex items-center gap-4">
            <div class="w-10 h-10 rounded-xl flex items-center justify-center"
                 style="background: rgba(34,211,238,0.08); border: 1px solid rgba(34,211,238,0.15);">
              <span class="w-2.5 h-2.5 rounded-full bg-cyan-500"></span>
            </div>
            <div class="text-left">
              <p class="text-[10px] text-cyan-400 font-semibold uppercase tracking-[0.2em] mb-0.5">Midline</p>
