                <ul class="space-y-2 text-sm mb-5">
                  {[
                    ['Antibioterapia IV (pH 5–9)', true],
                    ['Hidratación IV prolongada', true],
                    ['Analgesia IV (morfina, etc.)', true],
                    ['Nutrición parenteral total', false],
