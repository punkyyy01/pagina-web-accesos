<!-- ═══════════════════════════════════════════════════════════════
     GSAP — Animaciones de scroll y micro-interacciones
═══════════════════════════════════════════════════════════════ -->
<script>
import { gsap } from 'gsap';
import { ScrollTrigger } from 'gsap/ScrollTrigger';
import { ScrollToPlugin } from 'gsap/ScrollToPlugin';
gsap.registerPlugin(ScrollTrigger, ScrollToPlugin);

// ── Hero entrance ─────────────────────────────────────────────────
const heroTl = gsap.timeline({ delay: 0.15 });
heroTl
  .from('#hero-eyebrow', { opacity: 0, x: -20, duration: 0.7, ease: 'power3.out' })
  .from('#hero-title',   { opacity: 0, y: 40, duration: 0.9, ease: 'power3.out' }, '-=0.4')
  .from('#hero-desc',    { opacity: 0, y: 24, duration: 0.7, ease: 'power3.out' }, '-=0.5')
  .from('#hero-pills',   { opacity: 0, y: 20, duration: 0.6, ease: 'power3.out' }, '-=0.4')
  .from('#hero-scroll',  { opacity: 0, y: 12, duration: 0.5, ease: 'power3.out' }, '-=0.3');

// Scroll dot bounce
gsap.to('#scroll-dot', {
  y: 18, duration: 1.4, repeat: -1, yoyo: true, ease: 'power1.inOut',
});

// ── Generic .reveal sections ──────────────────────────────────────
document.querySelectorAll<HTMLElement>('.reveal').forEach(el => {
  gsap.to(el, {
    opacity: 1,
    y: 0,
    duration: 0.75,
    ease: 'power3.out',
    scrollTrigger: {
      trigger: el,
      start: 'top 88%',
      once: true,
    },
  });
});

// ── Quick ref cards (stagger) ─────────────────────────────────────
gsap.to('#referencia .qref-card', {
  opacity: 1,
  y: 0,
  scale: 1,
  duration: 0.6,
  stagger: 0.1,
  ease: 'power3.out',
  scrollTrigger: {
    trigger: '#referencia .qref-card',
    start: 'top 88%',
    once: true,
  },
});

// ── Procedure steps (stagger cascade) ────────────────────────────
gsap.to('.step-reveal', {
  opacity: 1,
  x: 0,
  duration: 0.55,
  stagger: 0.08,
  ease: 'power3.out',
  scrollTrigger: {
    trigger: '#steps-list',
    start: 'top 85%',
    once: true,
  },
});

// ── Security cards ──────────────────────────────────────────────
gsap.to('#seguridad .card', {
  opacity: 1,
  y: 0,
  duration: 0.6,
  stagger: 0.1,
  ease: 'power3.out',
  scrollTrigger: {
    trigger: '#seguridad',
    start: 'top 85%',
    once: true,
  },
});

// ── Accordion logic with GSAP ─────────────────────────────────────
const accordions = document.querySelectorAll<HTMLElement>('[data-accordion]');

// Open first accordion by default
const firstItem = document.querySelector('[data-accordion="picc"]');
if (firstItem) {
  const content = firstItem.querySelector<HTMLElement>('.accordion-content')!;
  const icon    = firstItem.querySelector<SVGElement>('.accordion-icon')!;
  gsap.set(content, { height: 'auto' });
  gsap.set(icon, { rotate: 180 });
}

accordions.forEach(item => {
  const trigger = item.querySelector<HTMLElement>('.accordion-trigger')!;
  const content = item.querySelector<HTMLElement>('.accordion-content')!;
  const icon    = item.querySelector<SVGElement>('.accordion-icon')!;
  let isOpen = item.dataset.accordion === 'picc';

  trigger.addEventListener('click', () => {
    if (isOpen) {
      gsap.to(content, { height: 0, duration: 0.4, ease: 'power2.inOut' });
      gsap.to(icon, { rotate: 0, duration: 0.3, ease: 'power2.inOut' });
      trigger.setAttribute('aria-expanded', 'false');
      isOpen = false;
    } else {
      // Close all others
      accordions.forEach(other => {
        if (other === item) return;
        const otherContent = other.querySelector<HTMLElement>('.accordion-content')!;
        const otherIcon    = other.querySelector<SVGElement>('.accordion-icon')!;
        const otherTrigger = other.querySelector<HTMLElement>('.accordion-trigger')!;
        gsap.to(otherContent, { height: 0, duration: 0.3, ease: 'power2.inOut' });
        gsap.to(otherIcon, { rotate: 0, duration: 0.25 });
        otherTrigger.setAttribute('aria-expanded', 'false');
        // @ts-ignore
        other._accordionOpen = false;
      });
      gsap.fromTo(content,
        { height: 0 },
        { height: 'auto', duration: 0.5, ease: 'power3.out' }
      );
      gsap.to(icon, { rotate: 180, duration: 0.3, ease: 'power2.inOut' });
      trigger.setAttribute('aria-expanded', 'true');
      isOpen = true;
    }
  });
});

// ── Hero quick-jump pills → open corresponding accordion ─────────
document.querySelectorAll<HTMLAnchorElement>('a[data-target]').forEach(a => {
  a.addEventListener('click', () => {
    const target = a.dataset.target!;
    setTimeout(() => {
      const item = document.querySelector<HTMLElement>(`[data-accordion="${target}"]`);
      if (!item) return;
      const trigger = item.querySelector<HTMLElement>('.accordion-trigger')!;
      const content = item.querySelector<HTMLElement>('.accordion-content')!;
      const icon    = item.querySelector<SVGElement>('.accordion-icon')!;
      const currentHeight = content.offsetHeight;
      if (currentHeight === 0) {
        accordions.forEach(other => {
          const oc = other.querySelector<HTMLElement>('.accordion-content')!;
          const oi = other.querySelector<SVGElement>('.accordion-icon')!;
          gsap.to(oc, { height: 0, duration: 0.25 });
          gsap.to(oi, { rotate: 0, duration: 0.2 });
          other.querySelector<HTMLElement>('.accordion-trigger')!.setAttribute('aria-expanded', 'false');
        });
        gsap.fromTo(content, { height: 0 }, { height: 'auto', duration: 0.5, ease: 'power3.out' });
        gsap.to(icon, { rotate: 180, duration: 0.3 });
        trigger.setAttribute('aria-expanded', 'true');
      }
    }, 1000);
  });
});

// ── Parallax on section titles ─────────────────────────────────────
document.querySelectorAll<HTMLElement>('.section-title').forEach(el => {
  gsap.to(el, {
    yPercent: -8,
    ease: 'none',
    scrollTrigger: {
      trigger: el.closest('section'),
      start: 'top bottom',
      end: 'bottom top',
      scrub: true,
    },
  });
});
</script>
