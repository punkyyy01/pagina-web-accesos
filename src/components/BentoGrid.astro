---
/**
 * BentoGrid.astro — Rediseño editorial
 * Cuadrícula asimétrica de 4 dispositivos de acceso vascular.
 */
---

<div class="bento-wrapper grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5 auto-rows-fr"
     style="grid-auto-rows: minmax(220px, auto);">

  <!-- ── PICC — protagonista (tall card) ────────────────────────── -->
  <div class="bento-card lg:row-span-2 relative overflow-hidden group">
    <!-- Accent top border -->
    <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-emerald-500/50 via-emerald-500/20 to-transparent"></div>

    <!-- Header -->
    <div class="flex items-start justify-between">
      <div>
        <div class="flex items-center gap-2.5 mb-2">
          <span class="w-2 h-2 rounded-full bg-emerald-500 shadow-[0_0_10px_rgba(52,211,153,0.4)]"></span>
          <span class="text-[10px] font-semibold text-emerald-400 uppercase tracking-[0.2em]">PICC</span>
        </div>
        <h3 class="text-xl font-bold text-white leading-snug" style="font-family: var(--font-display);">
          Catéter Central<br/>de Inserción Periférica
        </h3>
      </div>
      <span class="badge badge-central mt-0.5 shrink-0">Central</span>
    </div>

    <!-- Key fact -->
    <div class="rounded-xl p-4 relative overflow-hidden"
         style="background: linear-gradient(135deg, rgba(52,211,153,0.06), rgba(52,211,153,0.02)); border: 1px solid rgba(52,211,153,0.12);">
      <p class="text-[10px] text-emerald-400 font-semibold uppercase tracking-[0.15em] mb-1.5">Punta — Posición objetivo</p>
      <p class="text-[15px] text-white font-semibold">VCS / Unión cavoatrial</p>
      <p class="text-xs mt-1" style="color: var(--muted);">Tercio inferior de la Vena Cava Superior</p>
    </div>

    <!-- Stats -->
    <div class="stat-grid text-sm">
      <div>
        <p class="stat-label">Inserción</p>
        <p class="stat-value">Fosa antecubital</p>
      </div>
      <div>
        <p class="stat-label">Longitud</p>
        <p class="stat-value">45–65 cm</p>
      </div>
      <div>
        <p class="stat-label">Calibre</p>
        <p class="stat-value">3–6 Fr</p>
      </div>
      <div>
        <p class="stat-label">Duración</p>
        <p class="stat-value">Semanas–meses</p>
      </div>
    </div>

    <!-- Indications -->
    <div>
      <p class="text-[10px] font-semibold uppercase tracking-[0.15em] mb-2.5" style="color: var(--subtle);">Indicaciones</p>
      <div class="flex flex-wrap gap-1.5">
        <span class="ind-pill yes">NPT</span>
        <span class="ind-pill yes">Quimioterapia</span>
        <span class="ind-pill yes">Antibioterapia</span>
        <span class="ind-pill yes">Hemoderivados</span>
        <span class="ind-pill yes">pH &lt; 5 o &gt; 9</span>
      </div>
    </div>

    <!-- Confirmación -->
    <div class="alert alert-info mt-auto">
      <svg class="w-4 h-4 text-blue-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
      <p class="text-xs text-blue-300/90">Confirmar posición con <strong class="text-blue-300">ECG intravascular</strong> o <strong class="text-blue-300">Rx tórax</strong>.</p>
    </div>
  </div>

  <!-- ── CVC Subclavio ───────────────────────────────────────────── -->
  <div class="bento-card relative overflow-hidden group">
    <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-orange-500/50 via-orange-500/20 to-transparent"></div>

    <div class="flex items-start justify-between">
      <div>
        <div class="flex items-center gap-2.5 mb-2">
          <span class="w-2 h-2 rounded-full bg-orange-500 shadow-[0_0_10px_rgba(251,146,60,0.3)]"></span>
          <span class="text-[10px] font-semibold text-orange-400 uppercase tracking-[0.2em]">CVC Subclavio</span>
        </div>
        <h3 class="text-base font-bold text-white" style="font-family: var(--font-display);">Catéter Venoso Central<br/>Abordaje Subclavio</h3>
      </div>
      <span class="badge badge-central mt-0.5 shrink-0">Central</span>
    </div>

    <div class="stat-grid text-sm">
      <div>
        <p class="stat-label">Punta</p>
        <p class="stat-value">VCS tercio inferior</p>
      </div>
      <div>
        <p class="stat-label">Longitud</p>
        <p class="stat-value">15–20 cm</p>
      </div>
      <div>
        <p class="stat-label">Inserción</p>
        <p class="stat-value">1/3 medio clavícula</p>
      </div>
      <div>
        <p class="stat-label">Calibre</p>
        <p class="stat-value">7–8.5 Fr</p>
      </div>
    </div>

    <div class="alert alert-warn mt-auto">
      <svg class="w-4 h-4 text-amber-400 mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20">
        <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
      </svg>
      <p class="text-xs text-amber-300/90"><strong class="text-amber-300">Rx tórax obligatoria.</strong> Riesgo de neumotórax ~2%.</p>
    </div>
  </div>

  <!-- ── CVC Yugular ────────────────────────────────────────────── -->
  <div class="bento-card relative overflow-hidden group">
    <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-violet-500/50 via-violet-500/20 to-transparent"></div>

    <div class="flex items-start justify-between">
      <div>
        <div class="flex items-center gap-2.5 mb-2">
          <span class="w-2 h-2 rounded-full bg-violet-500 shadow-[0_0_10px_rgba(167,139,250,0.3)]"></span>
          <span class="text-[10px] font-semibold text-violet-400 uppercase tracking-[0.2em]">CVC Yugular</span>
        </div>
        <h3 class="text-base font-bold text-white" style="font-family: var(--font-display);">Catéter Venoso Central<br/>Abordaje Yugular Interno</h3>
      </div>
      <span class="badge badge-central mt-0.5 shrink-0">Central</span>
    </div>

    <div class="stat-grid text-sm">
      <div>
        <p class="stat-label">Punta</p>
        <p class="stat-value">VCS tercio inferior</p>
      </div>
      <div>
        <p class="stat-label">Longitud</p>
        <p class="stat-value">12–15 cm (derecho)</p>
      </div>
      <div>
        <p class="stat-label">Acceso</p>
        <p class="stat-value">Triángulo del ECM</p>
      </div>
      <div>
        <p class="stat-label">Calibre</p>
        <p class="stat-value">7–8.5 Fr</p>
      </div>
    </div>

    <div class="alert alert-success mt-auto">
      <svg class="w-4 h-4 text-emerald-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
      <p class="text-xs text-emerald-300/90">Guía ecográfica reduce complicaciones <strong class="text-emerald-300">~70%</strong>. Vía derecha preferida.</p>
    </div>
  </div>

  <!-- ── Midline (wide card) ────────────────────────────────────── -->
  <div class="bento-card lg:col-span-2 relative overflow-hidden group">
    <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-cyan-500/50 via-cyan-500/20 to-transparent"></div>

    <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-5">

      <!-- Left: info -->
      <div class="flex-1">
        <div class="flex items-center gap-2.5 mb-2">
          <span class="w-2 h-2 rounded-full bg-cyan-500 shadow-[0_0_10px_rgba(34,211,238,0.3)]"></span>
          <span class="text-[10px] font-semibold text-cyan-400 uppercase tracking-[0.2em]">Midline</span>
          <span class="badge badge-midline text-[10px] py-0.5">NO central</span>
        </div>
        <h3 class="text-base font-bold text-white mb-4" style="font-family: var(--font-display);">Catéter de Línea Media</h3>

        <div class="stat-grid text-sm">
          <div>
            <p class="stat-label">Punta</p>
            <p class="stat-value text-amber-400">Vena Axilar</p>
          </div>
          <div>
            <p class="stat-label">Longitud</p>
            <p class="stat-value">8–20 cm</p>
          </div>
          <div>
            <p class="stat-label">Duración</p>
            <p class="stat-value">1–4 semanas</p>
          </div>
          <div>
            <p class="stat-label">pH tolerado</p>
            <p class="stat-value">5 – 9</p>
          </div>
        </div>
      </div>

      <!-- Right: critical warning -->
      <div class="sm:w-64 shrink-0">
        <div class="alert alert-warn h-full">
          <svg class="w-4 h-4 text-amber-400 mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
          </svg>
          <div>
            <p class="text-xs text-amber-400 font-bold mb-2">Limitaciones críticas</p>
            <div class="space-y-1.5">
              <p class="text-xs flex gap-2" style="color: var(--muted);"><span class="text-red-400 font-bold">✗</span> Nutrición parenteral total</p>
              <p class="text-xs flex gap-2" style="color: var(--muted);"><span class="text-red-400 font-bold">✗</span> Osmolaridad &gt;600 mOsm/L</p>
              <p class="text-xs flex gap-2" style="color: var(--muted);"><span class="text-red-400 font-bold">✗</span> Quimioterapia vesicante</p>
              <p class="text-xs flex gap-2" style="color: var(--muted);"><span class="text-red-400 font-bold">✗</span> Fármacos vasoactivos conc.</p>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>

</div>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  gsap.set('.bento-card', { opacity: 0, y: 36, scale: 0.97 });
  gsap.to('.bento-card', {
    opacity: 1,
    y: 0,
    scale: 1,
    duration: 0.7,
    stagger: 0.12,
    ease: 'power3.out',
    scrollTrigger: {
      trigger: '.bento-wrapper',
      start: 'top 82%',
      once: true,
    },
  });
</script>
